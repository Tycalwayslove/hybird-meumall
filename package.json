{
  "name": "hybird-meumall",
  "version": "1.0.14",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "set -a && . config/env/h5.local.env && { [ ! -f ../.env.local ] || . ../.env.local; } && { [ ! -f .env.local ] || . .env.local; } && set +a && next dev -H ${H5_HOST:-localhost} -p ${H5_PORT:-3109}",
    "dev:test": "set -a && . config/env/h5.test.env && set +a && next dev -H ${H5_HOST:-localhost} -p ${H5_PORT:-3109}",
    "dev:prod": "set -a && . config/env/h5.prod.env && set +a && next dev -H ${H5_HOST:-localhost} -p ${H5_PORT:-3109}",
    "build:test": "set -a && . config/env/h5.test.env && set +a && next build",
    "build:prod": "set -a && . config/env/h5.prod.env && set +a && next build",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:commit": "commitlint --from HEAD~1 --to HEAD --verbose",
    "test": "vitest run",
    "prepare": "husky",
    "ai:create-task": "node scripts/ai/create-task.ts",
    "ai:diff-summary": "node scripts/ai/generate-diff-summary.ts",
    "ai:check-docs-sync": "node scripts/ai/check-docs-sync.ts",
    "ai:check-workflow": "node scripts/ai/check-workflow.ts",
    "ai:archive-task": "node scripts/ai/archive-task.ts",
    "ai:plan-task": "node scripts/ai/plan-task.ts",
    "ai:test-task": "node scripts/ai/test-task.ts",
    "ai:review-task": "node scripts/ai/review-task.ts",
    "ai:build-json": "node scripts/ai/generate-build-json.ts",
    "ai:release-prepare": "node scripts/ai/release-prepare.ts",
    "ai:prepare-ssr-release": "node scripts/ai/prepare-ssr-release.ts",
    "ai:prepare-standalone-assets": "node scripts/ai/prepare-standalone-assets.ts",
    "ai:register-release": "node scripts/ai/register-release.ts",
    "ai:smoke-ssr-release": "node scripts/ai/smoke-ssr-release.ts",
    "ai:resolve-manifest": "node scripts/ai/resolve-manifest.ts",
    "ai:update-changelog": "node scripts/ai/update-changelog.ts",
    "ai:update-manifest": "node scripts/ai/update-manifest.ts",
    "ai:rollback": "node scripts/ai/rollback.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.15.0",
    "html-react-parser": "^6.1.3",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
