# H5 local development profile.
# 当前阶段本地调试也连接测试 H5 配置和测试后端，便于前后端联调口径一致。
APP_ENV=local
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_H5_VERSION=2026.06.11-local

H5_HOST=localhost
H5_PORT=3109
PORT=3109
HOSTNAME=localhost

H5_SERVICE_BASE_URL=https://hybird.aigcpop.com
H5_RELEASE_SERVER_URL=https://hybird.aigcpop.com
H5_MANIFEST_URL=https://hybird.aigcpop.com/api/h5/manifest/active?environment=prod
NEXT_PUBLIC_H5_MANIFEST_URL=https://hybird.aigcpop.com/api/h5/manifest/active?environment=prod
NEXT_PUBLIC_CONFIG_API_BASE_URL=https://hybird.aigcpop.com

H5_BASE_PATH=/hybird
NEXT_PUBLIC_H5_BASE_PATH=/hybird
H5_HEALTH_CHECK_PATH=/api/health
H5_RELEASE_VARIANT=local
H5_RELEASE_LABEL="LOCAL TEST-CONFIG"

NEXT_PUBLIC_API_BASE_URL=/api/bff
JAVA_API_BASE_URL=https://test.aigcpop.com/mini_h5
JAVA_OSS_ASSET_BASE_URL=https://awu-mall-file.oss-cn-guangzhou.aliyuncs.com/
PYTHON_API_BASE_URL=https://test.aigcpop.com/api
H5_BFF_LOG_BACKEND_RESPONSE=1
H5_BFF_BACKEND_RESPONSE_LOG_LIMIT=30000
