{
  "runtime": "node-standalone",
  "entry": ".next/standalone/server.js",
  "standaloneDir": ".next/standalone",
  "staticDir": ".next/static",
  "publicDir": "public",
  "serviceBaseUrl": "https://h5.example.com",
  "basePath": "/hybird",
  "publicAssetBaseUrl": "https://cdn.example.com/meumall/h5/2026.05.15-001",
  "healthCheckPath": "/api/health",
  "smokeRoutes": ["/", "/category", "/cart", "/profile"],
  "requiredEnv": ["NODE_ENV", "PORT", "HOSTNAME", "H5_BASE_PATH"],
  "cacheControl": {
    "html": "private, no-cache, no-store, max-age=0, must-revalidate",
    "static": "public, max-age=31536000, immutable",
    "manifest": "no-cache, max-age=0, must-revalidate"
  }
}
