# Public client-safe values. Anything prefixed with NEXT_PUBLIC_ is visible in browser bundles.
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_H5_VERSION=2026.05.15-local
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Server-side or CI release values. Do not expose these through NEXT_PUBLIC_*.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=<your-bucket>
OSS_REGION=<your-region>
OSS_ENDPOINT=<your-endpoint>
