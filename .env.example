# Public client-safe values. Anything prefixed with NEXT_PUBLIC_ is visible in browser bundles.
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_H5_VERSION=2026.05.15-local
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_H5_MANIFEST_URL=http://127.0.0.1:4100/api/h5/manifest/active?environment=prod

# Server-side or CI SSR release values. Do not expose these through NEXT_PUBLIC_*.
H5_MANIFEST_URL=http://127.0.0.1:4100/api/h5/manifest/active?environment=prod
H5_SERVICE_BASE_URL=https://h5.example.com
H5_RELEASE_SERVER_URL=http://127.0.0.1:4100
H5_BASE_PATH=/hybird
H5_HEALTH_CHECK_PATH=/api/health
H5_RELEASE_VARIANT=blue
H5_RELEASE_LABEL="BLUE 2026.05.16"
PORT=3000
HOSTNAME=0.0.0.0
